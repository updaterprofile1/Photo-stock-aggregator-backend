generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String      @id @default(uuid()) @db.Uuid
  email      String      @unique
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")

  portfolios Portfolio[]

  @@map("users")
}

model Portfolio {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  assets Asset[]

  @@map("portfolios")
}

enum ContentOrigin {
  ai
  non_ai @map("non-ai")

  @@map("content_origin")
}

enum AssetStatus {
  draft
  ready
  submitted
  accepted
  rejected
  distributed
  original_deleted
  thumbnail_only

  @@map("asset_status")
}

enum RetentionState {
  active
  deleted
  archived

  @@map("retention_state")
}

model Asset {
  id                  String         @id @default(uuid()) @db.Uuid
  portfolioId         String         @map("portfolio_id") @db.Uuid
  title               String
  description         String?
  keywords            String[]       @default([])
  contentOrigin       ContentOrigin  @map("content_origin")
  status              AssetStatus    @default(draft)
  fileUrl             String         @map("file_url")
  storageKey          String?        @map("storage_key")
  thumbnailUrl        String?        @map("thumbnail_url")
  thumbnailStorageKey String?        @map("thumbnail_storage_key")
  retentionState      RetentionState @default(active) @map("retention_state")
  originalDeletedAt   DateTime?      @map("original_deleted_at")
  metadataScore       Float          @default(0) @map("metadata_score")
  createdAt           DateTime       @default(now()) @map("created_at")
  updatedAt           DateTime       @updatedAt @map("updated_at")

  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@map("assets")
}
